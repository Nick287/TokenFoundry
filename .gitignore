# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env
.env.*
!.env.example
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / frontend
node_modules/
portal/dist/
*.local

# Azure / IaC
*.azureauth
.azure/
# Compiled Bicep output (generated by `az bicep build`)
infra/main.json
infra/*.json
!infra/main.bicepparam
!infra/dashboards/*.json

# Playwright MCP (browser automation artifacts — console logs, page snapshots)
.playwright-mcp/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
*.swp

# Secrets — never commit
*.pem
*.pfx
secrets.json
local.settings.json

# Internal status/working notes (contain live infra endpoints — keep local)
STATUS.md

# AI assistant working dir (plans, research scratch — keep local)
.claude/

# TS incremental build cache (machine-generated)
*.tsbuildinfo

# Local dev SQLite (control-plane metadata scratch — never commit)
*.db

# Terraform (provider cache is ~250MB; state/vars carry secrets — never commit)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
*.tfplan
*.plan

# One-off verification / redeploy scratch scripts (underscore-prefixed)
scripts/_*.py
