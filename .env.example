# Token Foundry — environment contract. Copy to .env for local dev.
# Container Apps injects these as app settings / Key Vault references in cloud.
# NEVER commit a filled-in .env — it's gitignored.

TF_ENVIRONMENT=local

# Azure targets
TF_AZURE_SUBSCRIPTION_ID=
TF_RESOURCE_GROUP=
TF_APIM_SERVICE_NAME=

# Metadata DB (PostgreSQL)
TF_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tokenfoundry

# Usage store (Cosmos DB for NoSQL)
TF_COSMOS_ENDPOINT=
TF_COSMOS_DATABASE=tokenfoundry
TF_COSMOS_USAGE_CONTAINER=usage

# Key Vault
TF_KEYVAULT_URI=

# Application Insights (resource id for monitor-query)
TF_APP_INSIGHTS_RESOURCE_ID=

# AuthN — platform admins (Microsoft Entra ID)
TF_ENTRA_TENANT_ID=
TF_ENTRA_API_AUDIENCE=

# AuthN — customers (Microsoft Entra External ID / CIAM)
TF_EXTERNAL_ID_AUTHORITY=
TF_EXTERNAL_ID_AUDIENCE=
