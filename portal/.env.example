# Token Foundry portal — frontend env contract. Copy to portal/.env for local dev.

# Backend API base (dev uses Vite proxy -> /api)
VITE_API_BASE=/api
VITE_API_TARGET=http://localhost:8000

# Local dev auth bypass — mirrors the backend dev short-circuit.
#   admin:     dev:admin:
#   customer:  dev:customer:tn_xxxxxxxx
VITE_DEV_TOKEN=dev:admin:

# Entra ID (admins) / External ID (customers) — fill for cloud auth
VITE_ENTRA_TENANT_ID=
VITE_EXTERNAL_ID_AUTHORITY=
VITE_SPA_CLIENT_ID=
VITE_API_SCOPE=api://token-foundry/.default
