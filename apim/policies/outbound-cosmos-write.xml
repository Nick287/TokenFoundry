<!--
  Token Foundry — outbound usage capture (方案 A: APIM 直写 Cosmos).

  每次成功的 LLM 调用，APIM 用系统托管身份（AAD 鉴权，免 master key）以
  send-one-way-request（fire-and-forget，不阻塞 LLM 主链路）往 Cosmos 的
  usage 容器写一条记录：元数据 + 完整后端响应 JSON（raw_response）。

  token 不在此处解析（Anthropic/gpt-5.x/标准 OpenAI 格式各异）——只存原始
  JSON，读取端按格式提取。这是"尽力而为"写入：写失败无重试（MVP 取舍）。

  前置条件：
    * APIM 系统身份持有 Cosmos "Built-in Data Contributor"（…0002）数据平面角色
    * Cosmos 账户 disableLocalAuth=true，只接受 AAD（type=aad&ver=1.0&sig=<token>）
  实测确认：resource="https://cosmos.azure.com"，写入返回 201 + _rid/_etag。

  本片段的 inbound 段（authentication-managed-identity 取 token）必须与各
  provider API 的 inbound 合并；此文件给出 anthropic 的完整形态作为样板，
  openai/google 同构（仅 backend-id / api 维度不同）。
-->
<policies>
	<inbound>
		<base />
		<set-backend-service backend-id="llm-anthropic" />
		<llm-token-limit counter-key="@(context.Subscription.Id)" tokens-per-minute="50000" estimate-prompt-tokens="false" remaining-tokens-header-name="x-remaining-tokens" tokens-consumed-header-name="x-consumed-tokens" />
		<llm-emit-token-metric namespace="tokenfoundry">
			<dimension name="subscription" value="@(context.Subscription.Id)" />
			<dimension name="api" value="@(context.Api.Id)" />
		</llm-emit-token-metric>
		<!-- 取 Cosmos 数据平面 AAD token（此策略只能在 inbound） -->
		<authentication-managed-identity resource="https://cosmos.azure.com" output-token-variable-name="cosmosToken" ignore-error="true" />
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
		<!-- 仅对成功响应写库；token 取不到时也无所谓（只存原始 JSON） -->
		<choose>
			<when condition="@(context.Response.StatusCode == 200 && context.Variables.ContainsKey("cosmosToken"))">
				<send-one-way-request mode="new">
					<set-url>https://tokenfoundry2-cosmos-3d7rw53usrauy.documents.azure.com/dbs/tokenfoundry/colls/usage/docs</set-url>
					<set-method>POST</set-method>
					<set-header name="Authorization" exists-action="override">
						<value>@(System.Net.WebUtility.UrlEncode("type=aad&ver=1.0&sig=" + (string)context.Variables["cosmosToken"]))</value>
					</set-header>
					<set-header name="x-ms-date" exists-action="override">
						<value>@(DateTime.UtcNow.ToString("r"))</value>
					</set-header>
					<set-header name="x-ms-version" exists-action="override">
						<value>2018-12-31</value>
					</set-header>
					<set-header name="x-ms-documentdb-partitionkey" exists-action="override">
						<value>@("[\"" + context.Subscription.Id + "_" + DateTime.UtcNow.ToString("yyyyMM") + "\"]")</value>
					</set-header>
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-body>@{
						var doc = new JObject();
						doc["id"] = context.RequestId;
						doc["pk"] = context.Subscription.Id + "_" + DateTime.UtcNow.ToString("yyyyMM");
						doc["ts"] = DateTime.UtcNow.ToString("o");
						doc["subscription"] = context.Subscription.Id;
						doc["tenant"] = context.Request.Headers.GetValueOrDefault("x-tf-tenant", "unknown");
						doc["route"] = context.Request.Headers.GetValueOrDefault("x-tf-route", "unknown");
						doc["region"] = context.Deployment.Region;
						doc["api"] = context.Api.Id;
						try {
							doc["raw_response"] = context.Response.Body.As<JObject>(preserveContent: true);
						} catch (Exception) {
							doc["raw_response"] = null;
						}
						return doc.ToString();
					}</set-body>
				</send-one-way-request>
			</when>
		</choose>
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>
