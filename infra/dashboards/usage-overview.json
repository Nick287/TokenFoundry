{
  "__comment": "Token Foundry — usage/cost/TPM + request-latency dashboard. Targets the Managed Grafana out-of-box Azure Monitor data source (uid azure-monitor-oob) and queries the App Insights component via azureLogAnalytics.resources. Token panels read customMetrics (emit-token-metric policy — only populated once the gateway can parse backend token usage); latency panels read requests/dependencies, which require the APIM applicationinsights diagnostic (see infra/modules/apim.bicep). The Grafana managed identity needs Monitoring Reader on the resource group.",
  "title": "Token Foundry — Usage & Cost",
  "uid": "token-foundry-usage",
  "schemaVersion": 39,
  "version": 2,
  "tags": ["token-foundry", "llm", "finops"],
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "appinsights",
        "type": "constant",
        "hide": 2,
        "query": "/subscriptions/655bd0bc-917a-4852-a52c-4b6d43704bc1/resourceGroups/tokenfoundry2-rg/providers/Microsoft.Insights/components/tokenfoundry2-appi",
        "current": {
          "value": "/subscriptions/655bd0bc-917a-4852-a52c-4b6d43704bc1/resourceGroups/tokenfoundry2-rg/providers/Microsoft.Insights/components/tokenfoundry2-appi"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total tokens by tenant (24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": ["$appinsights"],
            "query": "customMetrics | where name == 'llm-total-tokens' | extend tenant = tostring(customDimensions['tenant']) | summarize tokens = sum(value) by tenant"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Tokens by model route (24h)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": ["$appinsights"],
            "query": "customMetrics | where name == 'llm-total-tokens' | extend route = tostring(customDimensions['route']) | summarize tokens = sum(value) by route"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "TPM over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": ["$appinsights"],
            "query": "customMetrics | where name == 'llm-total-tokens' | summarize tokens = sum(value) by bin(timestamp, 1m)"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Request latency p50/p95/p99 by API (1h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": ["$appinsights"],
            "query": "requests | where timestamp > ago(1h) | summarize p50 = percentile(duration, 50), p95 = percentile(duration, 95), p99 = percentile(duration, 99) by bin(timestamp, 5m), name | order by timestamp asc"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Gateway overhead vs backend time (avg, 1h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": ["$appinsights"],
            "query": "requests | where timestamp > ago(1h) | join kind=leftouter (dependencies | where type == 'Http' | project operation_Id, backend_ms = duration) on operation_Id | extend gateway_ms = duration - coalesce(backend_ms, 0.0) | summarize avg_backend_ms = avg(backend_ms), avg_gateway_ms = avg(gateway_ms) by bin(timestamp, 5m) | order by timestamp asc"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Slowest calls (1h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azure-monitor-oob" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": ["$appinsights"],
            "query": "requests | where timestamp > ago(1h) | project timestamp, name, duration, resultCode, url | order by duration desc | take 20"
          }
        }
      ]
    }
  ]
}
